{
  "name": "flag-frolic-trivia",
  "version": "1.0.0",
  "main": "main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "electron:build": "npm run build && electron-builder"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.22.3"
  },
  "devDependencies": {
    "@vitejs/plugin-react-swc": "^3.5.0",
    "electron": "^31.7.7",
    "electron-builder": "^24.13.3",
    "typescript": "^5.2.2",
    "vite": "^5.4.0"
  },
  "build": {
    "appId": "com.sergi.flagfrolic",
    "productName": "FlagFrolic",
    "directories": {
      "output": "dist_electron"
    },
    "files": [
      "dist/**/*",
      "main.js",
      "package.json"
    ],
    "linux": {
      "target": ["AppImage"],
      "category": "Game"
    }
  }
}
