{
  "name": "flag-frolic-trivia",
  "version": "1.0.0",
  "type": "module",
  "main": "main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "electron:build": "npm run build && electron-builder"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.22.3",
    "lucide-react": "^0.344.0",
    "clsx": "^2.1.0",
    "tailwind-merge": "^2.2.1",
    "tailwindcss-animate": "^1.0.7",
    "@radix-ui/react-slot": "^1.0.2",
    "@tanstack/react-query": "^5.25.0",
    "uuid": "^9.0.1",
    "@supabase/supabase-js": "^2.39.7",
    "sonner": "^1.4.3",
    "next-themes": "^0.3.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react-swc": "^3.5.0",
    "@types/uuid": "^9.0.8",
    "electron": "^31.7.7",
    "electron-builder": "^24.13.3",
    "typescript": "^5.2.2",
    "vite": "^5.4.0",
    "tailwindcss": "^3.4.1",
    "autoprefixer": "^10.4.17",
    "postcss": "^8.4.35"
  },
  "build": {
    "appId": "com.sergi.flagfrolic",
